rules_version = '2';

// Aturan keamanan Firestore untuk FlowNote
// Hanya user yang terautentikasi yang dapat mengakses data miliknya sendiri
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Profil User ──────────────────────────────────────────────────────────
    match /users/{userId} {
      // User hanya bisa baca/tulis profil diri sendiri
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Transaksi ─────────────────────────────────────────────────────────────
    match /transactions/{userId}/items/{txId} {
      // User hanya bisa akses transaksi miliknya
      allow read, write, create, update, delete:
        if request.auth != null && request.auth.uid == userId;
    }

    // ── Catatan ───────────────────────────────────────────────────────────────
    match /notes/{userId}/items/{noteId} {
      allow read, write, create, update, delete:
        if request.auth != null && request.auth.uid == userId;
    }

    // ── Kategori ──────────────────────────────────────────────────────────────
    match /categories/{userId}/items/{catId} {
      allow read, write, create, update, delete:
        if request.auth != null && request.auth.uid == userId;
    }

    // Tolak semua akses lain secara default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
